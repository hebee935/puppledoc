{
  "name": "@puppledoc/nestjs-api-reference",
  "version": "1.0.4",
  "description": "NestJS API reference: OpenAPI 3.1 + x-websocket extension with a bundled docs / test UI",
  "keywords": [
    "nestjs",
    "swagger",
    "openapi",
    "websocket",
    "api-docs",
    "x-websocket"
  ],
  "license": "MIT",
  "author": "Space API contributors",
  "homepage": "https://github.com/hebee935/puppledoc#readme",
  "bugs": {
    "url": "https://github.com/hebee935/puppledoc/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hebee935/puppledoc",
    "directory": "packages/api"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "ui",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist ui .turbo",
    "bundle-ui": "rm -rf ui && cp -R ../api-ui/dist ui",
    "prepublishOnly": "pnpm run build && pnpm run bundle-ui"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "@nestjs/swagger": "^7 || ^8",
    "@nestjs/websockets": "^10 || ^11",
    "reflect-metadata": "^0.2.0"
  },
  "devDependencies": {
    "@puppledoc/space-ui": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
