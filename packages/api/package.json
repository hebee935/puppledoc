{
  "name": "@space/api",
  "version": "0.1.0",
  "description": "NestJS plugin: OpenAPI 3.1 + x-websocket extension with a Scalar-like docs/test UI",
  "keywords": ["nestjs", "swagger", "openapi", "websocket", "scalar", "api-docs", "asyncapi"],
  "license": "MIT",
  "author": "Space API contributors",
  "homepage": "https://github.com/OWNER/space-api#readme",
  "bugs": {
    "url": "https://github.com/OWNER/space-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OWNER/space-api.git",
    "directory": "packages/api"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@nestjs/common": "^10 || ^11",
    "@nestjs/core": "^10 || ^11",
    "@nestjs/swagger": "^7 || ^8",
    "@nestjs/websockets": "^10 || ^11",
    "reflect-metadata": "^0.2.0"
  },
  "dependencies": {
    "@space/api-ui": "workspace:*"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
