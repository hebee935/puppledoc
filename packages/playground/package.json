{
  "name": "playground",
  "version": "0.0.0",
  "private": true,
  "description": "Local NestJS app to smoke-test @space/api end-to-end",
  "scripts": {
    "dev": "ts-node-dev --transpile-only --respawn src/main.ts",
    "start": "node --loader ts-node/esm src/main.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/platform-ws": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/websockets": "^10.4.15",
    "@space/api": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "express": "^4.21.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "@types/ws": "^8.5.13",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
